<%- company_admin_user = current_user.company_users.find_by_company_id(current_user.company_id) %>

<ol class="breadcrumb">
  <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
  <li class="breadcrumb-item active">Users</li>
  <div class="pull-right">
    <%-if company_admin_user&.is_company_admin == true %>
  
      <button class="btn btn-secondary btn-rounded btn-sm"  data-toggle="modal" data-target="#importUsers"><i class="fa fa-plus"></i> Import Users</button>
    <% end %>
    <%= link_to raw("<i class='fa fa-plus'></i> Add User"), new_user_path, class: "btn btn-primary btn-rounded btn-sm" %>
    
  </div>
</ol>

<%= render :partial => 'user_filter' %>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <%-if current_user && current_user.is_admin? %>
        <th>Company</th>
      <% end %>
      <th>Address</th>
      <th>Permissions</th>
      <th>Telephone</th>
      <th>Created</th>
      <%-if current_user && current_user.is_admin? %>
        <th>Edit</th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>  
      <tr>
        <td><%= link_to user.display_name, user %></td>
        <td><%= user.email %></td>
        <%-if current_user && current_user.is_admin? %>
          <td><%= user.company&.name %></td>
        <% end %>

        <td><%= user.address %></td>
        <%- company_user = user.company_users.find_by_company_id(user.company_id) %>
        <td>
          <%= !company_user.nil? && !company_user.license_code.nil? && company_user.license_code.length > 0 ? '<span class="btn btn-primary btn-rounded btn-sm">Licensed</span>'.html_safe : "" %>
          <%= user.has_iap? ? '<span class="btn btn-primary btn-rounded btn-sm">IAP</span>'.html_safe : "" %>
          <%= !user.is_admin && !company_user.nil? && company_user.is_company_admin ? '<span class="btn btn-info btn-rounded btn-sm">Admin</span>'.html_safe : "" %>
          <%= user.is_admin ? '<span class="btn btn-danger btn-rounded btn-sm">Super User</span>'.html_safe : "" %>
          <%= user.call_on_false_alarm ? '<span class="btn btn-info btn-rounded btn-sm">Always Call</span>'.html_safe : "" %>
          
        </td>
        <td><%= user.telephone_number %></td>
        <td><%= user.created_at.strftime("%d/%m/%Y %H:%M") %></td>
        <%-if current_user && current_user.is_admin? %>
          <td>
            <%= link_to "Remove", user, method: :delete, data: { confirm: 'Are you sure you want to delete this User?' }, class: "btn btn-danger btn-rounded btn-sm" %>
            <%= link_to "Edit", edit_user_path(user), class: "btn btn-primary btn-rounded btn-sm" %>
          </td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>
<%= paginate @users %>


<%-if company_admin_user&.is_company_admin == true %>
  <div class="modal inmodal fade" id="importUsers" tabindex="-1" role="dialog"  aria-hidden="true">
      <div class="modal-dialog modal-lg">
          <div class="modal-content">
              <div class="modal-header ">
                  <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">&times;</span><span class="sr-only">Close</span></button>
                  <h4 class="modal-title">Import Users</h4>
              </div>
			
    					<%= form_tag import_company_users_path(current_company), multipart: true do %>
                <div class="modal-body">
                
        						<%= file_field_tag :file %>
              
                </div>

                <div class="modal-footer">
                  <%= submit_tag "Save", class: "btn btn-primary" %>
                    <button type="button" class="btn btn-white" data-dismiss="modal">Close</button>
                </div>
    					<% end %>
          </div>
      </div>
  </div>
<% end %>
