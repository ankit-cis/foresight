
<div class="col-lg-4 offset-lg-4">
    <div class="card m-t-3">
        <h1 class="card-header icon-title text-center">Log In</h1>

        <div class="card-block">
          <%= form_tag sessions_path do %>
            <div class="form-group">
              <%= label_tag :email %><br />
              <%= text_field_tag :email, params[:email], class: "form-control" %>
            </div>
            <div class="form-group">
              <%= label_tag :password %><br />
              <%= password_field_tag :password, "", class: "form-control password" %>
            </div>
            <div class="btn-toolbar pull-right" role="toolbar">
              <%= link_to "Forgotten Your Password?", new_password_reset_path, class: "btn btn-link btn-lg" %>
              <%= submit_tag "Log In", class: "btn btn-primary btn-lg"%>                
            </div>
          <% end %>
        </div>
    </div>
</div>
