<div class="card">
  <div class="card-header">
    <strong>User Information</strong>
    <div class="pull-right">
      <%= link_to "Resend Welcome Email", resend_welcome_email_user_path(@user), class: "btn btn-primary btn-rounded btn-sm", data: { confirm: 'Are you sure? The users password will be reset.' } %>
    </div>
  </div>
  <div class="card-block">

    <div class="row">
      <div class="col-xs-6 col-md-6">
  		  <strong>Email:</strong>
  		  <p><%= @user.email %></p>
        
      </div>

      <div class="col-xs-6 col-md-6">
        <strong>Forename:</strong>
        <p><%= @user.forename %></p>
      </div>

      <div class="col-xs-6 col-md-6">
        <strong>Surname:</strong>
        <p><%= @user.surname %></p>
      </div>

      <div class="col-xs-6 col-md-6">            
        <strong>Title:</strong>
        <p><%= @user.title.nil? ? "" : @user.title.name %></p>
      </div>
      <div class="col-xs-6 col-md-6">            
        <strong>Promo Code:</strong>
        <p><%= @user.promo_code %></p>
      </div>
    </div>
  </div>
</div>