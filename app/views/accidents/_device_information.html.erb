<% @accident.videos.each do |video| %>
  <div class="card">
    <div class="card-header">
      Device Information
    </div>
    <div class="card-block">

      <div class="row">
        <div class="col-xs-6 col-md-6">
          <strong>Platform:</strong>
          <p><%= video.system_name %></p>
        </div>

        <div class="col-xs-6 col-md-6">
          <strong>Platform Version:</strong>
          <p><%= video.system_version %></p>
        </div>

        <div class="col-xs-6 col-md-6">
          <strong>Device Model:</strong>
          <p><%= video.device_model %></p>
        </div>

        <div class="col-xs-6 col-md-6">            
          <strong>App Version:</strong>
          <p><%= video.app_version %></p>
        </div>
      </div>
    </div>
  </div>
<%end%>