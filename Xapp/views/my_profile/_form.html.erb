<%= simple_form_for(@user, :url => my_profile_path, :method => :patch) do |f| %>
  <% if user.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(user.errors.count, "error") %> prohibited this user from being saved:</h2>

      <ul>
      <% user.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <div class="col-md-6">

      <div class="card">
        <div class="card-header">
          User Information
          <%= f.submit "Save", class: "btn btn-primary btn-rounded btn-sm pull-right" %>
          
        </div>
        <div class="card-block">

          <div class="row">
            <div class="col-xs-6 col-md-6">
              <%= f.input :email %>
            </div>

            <div class="col-xs-6 col-md-6">
              <%= f.input :forename %>
            </div>

            <div class="col-xs-6 col-md-6">
              <%= f.input :surname %>
            </div>

            <div class="col-xs-6 col-md-6">            
              <%= f.association :title %>
            </div>
            
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-6">

      <div class="card">
        <div class="card-header">
          Profile Details
          <%= f.submit "Save", class: "btn btn-primary btn-rounded btn-sm pull-right" %>
          
        </div>
        <div class="card-block">

          <div class="row">

            <div class="col-xs-6 col-md-6">            
              <%= f.input :address %>
            </div>

            <div class="col-xs-6 col-md-6">
              <%= f.input :vehicle_registration %>
            </div>

            <div class="col-xs-6 col-md-6">            
              <%= f.input :insurer %>
            </div>

            <div class="col-xs-6 col-md-6">            
              <%= f.input :telephone_number %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
