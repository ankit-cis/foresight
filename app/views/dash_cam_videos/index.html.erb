<ol class="breadcrumb">
<li class="breadcrumb-item"><a href="/">Dashboard</a></li>
<li class="breadcrumb-item active">Dashcam Videos</li>
</ol>

<table class="table table-striped">
<thead>
  <tr>
  <th>Filename</th>
  <th>Uploaded At</th>
  <th>Play/Download</th>
  <th>Delete</th>

  </tr>
</thead>
<tbody>
  <% if @dashcam_videos.any? %>
    <% @dashcam_videos.each do |dashcam_video| %>
      <tr>
          <td><%= dashcam_video.file_name %></td>
          <td><%= dashcam_video.uploaded_at %></td>
          <td>
              <!-- Use the direct path in the 'src' attribute -->
              <video width="320" height="240" controls>
                <source src="<%= "/uploads/dash_cam_videos/#{dashcam_video.file_name}" %>" type="video/mp4">
                Your browser does not support the video tag.
              </video>
              <br>
          </td>
          <td>
              <%= link_to 'Delete', dash_cam_video_path(dashcam_video), 
                  method: :delete, 
                  data: { confirm: 'Are you sure you want to delete this video?' } %>
          </td>
      </tr>
    <% end %>
  <% else %>
    <tr>
      <td colspan="4" style="text-align: center; font-weight: bold;">
        No videos available
      </td>
    </tr>
  <% end %>
</tbody>

</table>
