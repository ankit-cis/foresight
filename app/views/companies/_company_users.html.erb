<div class="tab-pane fade <%= params[:tab] == 'users' ? 'active show' : '' %>" id="users" role="tabpanel">
  <table class="table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Is Admin?</th>
        <th>Licensed?</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <% company_user = user.company_users.where(company_id: @company.id).first %>
          <td><%= link_to user.display_name, user %></td>
          <td><%= user.email %></td>
          <td><span class="status"><%= company_user&.is_company_admin == true ? "Admin" : "" %></span></td>
          <td><%= company_user&.license_code && company_user&.license_code&.length > 0 ? "Yes" : "" %></td>
          <%-if current_user && current_user.is_admin? %>
            <td>
              <%= link_to "Remove", user_path(id: user.id, tab: 'users'), method: :delete, data: { confirm: 'Are you sure you want to delete this User?' }, class: "btn btn-danger btn-rounded btn-sm" %>
              <%= link_to "Edit", edit_user_path(id: user.id, tab: 'users'), class: "btn btn-primary btn-rounded btn-sm" %>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
  
</div>
