<div class="col-lg-4 offset-lg-4">
  <div class="card m-t-3">
    <div class="card-header text-center">

      <h3>Forgot password</h3>
      <p>Enter your email address and an email will be sent to you to take you through the reset process.</p>
    </div>
    <div class="card-block">
      <div class="row">
        <div class="col-lg-12">
          <%= form_tag password_resets_path, :method => :post do %>
            <div class="form-group">
            <%= text_field_tag :email, params[:email], placeholder: "Email address", class: "form-control" %>
            </div>

            <%= submit_tag "Send password reset email", class: "btn btn-primary block full-width m-b" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
