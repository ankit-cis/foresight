<div class="row">
  <%- if !current_user.nil? %>
    <a href="#menu-toggle" class="btn btn-default" id="menu-toggle">
      <span class="fa-stack fa-lg">
        <i class="fa fa-square-o fa-stack-2x"></i>
        <i class="fa fa-bars fa-stack-1x"></i>
      </span>
    </a>
    <div class="col-lg-3">
      <h1 class="text-primary"><%= controller.controller_name.titleize %></h1>
    </div>
  <% elsif params["commit"].present? && !params["commit"] == "Send password reset email" %>
    <div class="col-lg-12 text-center">
      <h1 class="text-primary">4Sight+</h1>
    </div>
  <% end %>
</div>
<hr>
