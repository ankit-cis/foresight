<ol class="breadcrumb">
  <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
  <li class="breadcrumb-item active">Companies</li>
  <div class="pull-right">
    <%= link_to raw("<i class='fa fa-plus'></i> Add Company"), new_company_path, class: "btn btn-primary btn-rounded btn-sm" %>    
  </div>
</ol>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Name</th>
      <th>Type</th>
      <th>Account Type</th>
      <th>Contact Name</th>
      <th>Email</th>
      <th>Telephone</th>
      <th>Action</th>
    </tr>
  </thead>

  <tbody>
    <% @companies.each do |company| %>
      <tr>
        <td><%= link_to company.name, company %></td>
        <td><%= company.company_type.name %></td>
        <td><%= company.payment_type.name %></td>
        <td><%= "#{company.forename} #{company.surname}" %></td>
        <td><%= company.email %></td>
        <td><%= company.telephone_number %></td>
        <td><%= link_to "Remove", company_path(id: company.id, tab: 'company'), method: :delete, data: { confirm: 'Are you sure you want to delete this company?' }, class: "btn btn-danger btn-rounded btn-sm" %></td>
      </tr>
    <% end %>
  </tbody>
</table>
