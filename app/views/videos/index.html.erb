<ol class="breadcrumb">
  <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
  <li class="breadcrumb-item active">Videos</li>
</ol>

<%= render :partial => 'video_filter' %>

<table class="table table-striped">
  <thead>
    <tr>
      <th>#</th>
      <th>User</th>
      <th>Detected at</th>
      <th>Status</th>
      <th>Accident Reported at</th>
      <%- if current_user.is_admin %>
        <th>Company</th>
        <th>Remove</th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% @videos.each do |video| %>
      <tr>
        <td><%= video.video_number %></td>
        <td><%= link_to video.user.display_name, video %></td>
        <td><%= time_ago_in_words(video.created_at) %> ago</td>
        
        <%
          if video.status.status_constant == "REPORTED"
            class_name = "btn-danger"
          elsif video.status.status_constant == "IN_PROGRESS"
            class_name = "btn-warning"
          else
            class_name = "btn-success"
          end 
        %>
        <td>
          <span class="btn btn-rounded btn-sm <%= class_name %>"><%= video.status.name %></span>
          <%= video.false_alarm ? '<span class="btn btn-warning btn-rounded btn-sm">False Alarm</span>'.html_safe : "" %>
          <%= video.user.call_on_false_alarm ? '<span class="btn btn-info btn-rounded btn-sm">Always Call</span>'.html_safe : "" %>
          
        </td>
        <td><%= time_ago_in_words(video.accident.created_at) if video.accident %></td>
        <%- if current_user.is_admin %>
          <td><%= video.company.name %></td>
	  <td><%= link_to "Remove", video, method: :delete, data: { confirm: 'Are you sure you want to delete this Video recording?' }, class: "btn btn-danger btn-rounded btn-sm" %></td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>
<%= paginate @videos %>
