<div class="col-lg-4 offset-lg-4">
  <div class="card">
    <div class="card-header text-center">

      <h3>Password Reset Email</h3>
    </div>
    <div class="card-block">
      <div class="row">
        <div class="col-lg-12">
          <p>An email has just been sent to <%= @email %> and should arrive shortly.</p>
          <p>This will guide you through resetting your password.</p>
        </div>
      </div>
    </div>
  </div>
</div>
